{
  "title": "Query Optimization",
  "uid": "optimization",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Top 5 Slowest Queries (mean_exec_time)",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "sortBy": [{ "displayName": "mean_exec_time ms", "desc": true }]
      },
      "targets": [
        {
          "rawSql": "SELECT LEFT(query, 80) AS query, calls, ROUND(total_exec_time::numeric, 2) AS total_exec_time_ms, ROUND(mean_exec_time::numeric, 2) AS mean_exec_time_ms, rows, shared_blks_hit, shared_blks_read FROM pg_stat_statements WHERE query NOT ILIKE '%pg_%' AND query NOT ILIKE '%typinput%' AND query NOT ILIKE '%nspname%' AND query NOT ILIKE '%application_name%' AND query NOT ILIKE '%EXPLAIN%' ORDER BY mean_exec_time DESC LIMIT 5;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT NOW() AS time, ROUND(100.0 * sum(blks_hit) / NULLIF(sum(blks_hit) + sum(blks_read), 0), 2) AS value FROM pg_stat_database WHERE datname = current_database();",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT NOW() AS time, count(*) AS value FROM pg_stat_activity WHERE state = 'active';",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ]
}
